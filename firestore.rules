rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidFile(data) {
      return data.keys().hasAll(['name', 'content', 'userId', 'updatedAt']) &&
             data.keys().size() <= 6 &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 255 &&
             data.content is string && data.content.size() <= 1048576 &&
             data.userId == request.auth.uid &&
             data.updatedAt == request.time;
    }

    // --- Collections ---
    match /files/{fileId} {
      allow get: if isSignedIn() && isOwner(existing().userId) && isValidId(fileId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidFile(incoming()) && isValidId(fileId);
      
      allow update: if isSignedIn() && 
                    isOwner(existing().userId) && 
                    isValidFile(incoming()) && 
                    incoming().userId == existing().userId &&
                    isValidId(fileId) &&
                    (
                      // Action: Standard Edit
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'content', 'updatedAt'])
                    );
      
      allow delete: if isSignedIn() && isOwner(existing().userId) && isValidId(fileId);
    }

    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['displayName', 'email', 'updatedAt']) &&
               data.displayName is string && data.displayName.size() <= 100 &&
               data.email is string && data.email.size() <= 255 &&
               data.updatedAt == request.time;
      }
      
      allow get: if isSignedIn() && (request.auth.uid == userId);
      allow create, update: if isSignedIn() && (request.auth.uid == userId) && isValidUser(incoming());
    }
  }
}
